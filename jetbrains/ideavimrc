''' para buscar una acción :actionlist <search>
set multiple-cursors
set showmode
let mapleader=" "

''' project
map <leader>pc <Action>(GotoClass)
map <leader>pf <Action>(GotoFile)
map <leader>ps <Action>(GotoSymbol)
map <leader>pa <Action>(GotoAction)
map <leader>pb <Action>(RecentChangedFiles)

''' file
map <leader>bs <Action>(SaveAll)
map <leader>bk <Action>(CloseContent)
map <leader>ba <Action>(CloseAllEditors)
map <leader>bp <Action>(Back)
map <leader>bn <Action>(Forward)
map <leader>bb <Action>(RecentChangedFiles)

''' window
map <leader>wh <Action>(MoveTabRight)
map <leader>ws <Action>(MoveTabDown)
map <leader>wn <Action>(NextSplitter)
map <leader>wp <Action>(PrevSplitter)
map <leader>wd <Action>(Unsplit)
map <leader>wa <Action>(UnsplitAll)

''' code
map <leader>ca <Action>(ShowIntentionActions)
map <leader>ci <Action>(GotoImplementation)
map <leader>cg <Action>(Generate)
map <leader>cr <Action>(ReformatCode)
map <leader>co <Action>(OptimizeImports)

set clipboard=unnamedplus
